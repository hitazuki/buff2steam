ASTRBOT_BASE_URL=http://astrbot:6185
ASTRBOT_API_KEY=abk_replace_with_im_scope_key
ASTRBOT_MESSAGE_PATH=/api/v1/im/message
ASTRBOT_TIMEOUT_SECONDS=10

BUFF2STEAM_IMAGE=docker.io/hitazuki/buff2steam:latest

BUFF2STEAM_SERVICE_TOKEN=replace_with_a_long_random_token
BUFF2STEAM_DATABASE=/app/data/monitor.db
BUFF2STEAM_BACKUP_DIR=/app/data/backups
BUFF2STEAM_INTERVAL_SECONDS=300
BUFF2STEAM_QUOTE_CACHE_SECONDS=60
BUFF2STEAM_MAX_ITEMS=20

SMIS_TIMEOUT_SECONDS=15
SMIS_MAX_RETRIES=3
TZ=Asia/Shanghai
